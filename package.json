{
  "name": "nps-ui-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo cho thư viện UI và website docs của NPS UI",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:docs": "npm run dev --workspace docs",
    "build:ui": "npm run build --workspace @namphuongtechnologi/nps-ui",
    "build:docs": "npm run build --workspace docs",
    "build": "npm run build:ui && npm run build:docs",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "change": "node scripts/nps-release-ui.js",
    "clean": "rm -rf dist node_modules packages/*/dist packages/*/node_modules apps/*/dist apps/*/node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "prettier": "^3.8.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}
